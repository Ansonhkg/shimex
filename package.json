{
  "name": "shimex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local provider gateway and managed Codex Desktop companion.",
  "bin": {
    "shimex": "./src/cli/main.js"
  },
  "scripts": {
    "shimex": "node src/cli/main.js",
    "start": "node src/cli/main.js start",
    "dev": "node src/cli/main.js dev",
    "status": "node src/cli/main.js status",
    "stop": "node src/cli/main.js stop",
    "test": "node --test",
    "check": "npm test && npm run shimex -- doctor",
    "stop:all": "node src/cli/main.js stop-all"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
